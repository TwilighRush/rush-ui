{
  "name": "@rush_ui/react",
  "version": "0.1.2",
  "private": false,
  "description": "面向后台与管理端场景的 React 组件库。",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/react.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/react.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TwilighRush/rush-ui.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/TwilighRush/rush-ui#readme",
  "bugs": {
    "url": "https://github.com/TwilighRush/rush-ui/issues"
  },
  "keywords": [
    "react",
    "components",
    "admin",
    "dashboard"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "scripts": {
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  }
}
