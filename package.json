{
  "name": "rush-ui-monorepo",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.6.3",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter './packages/**' --filter './apps/**' -r run build",
    "dev": "pnpm --filter @rush_ui/docs dev",
    "lint": "pnpm --filter './packages/**' --filter './apps/**' -r run lint",
    "typecheck": "pnpm --filter './packages/**' --filter './apps/**' -r run typecheck",
    "test": "pnpm --filter './packages/**' --filter './apps/**' -r run test",
    "storybook": "pnpm --filter @rush_ui/docs storybook",
    "storybook:build": "pnpm --filter @rush_ui/docs exec storybook build",
    "verify:package": "node scripts/verify-package.mjs",
    "setup-hooks": "git config core.hooksPath .githooks && chmod +x .githooks/commit-msg",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.2",
    "@eslint/js": "^9.23.0",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "^8.6.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "axe-core": "^4.10.3",
    "eslint": "^9.23.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "less": "^4.6.4",
    "storybook": "^8.6.12",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vite": "^6.2.2",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.0.9"
  }
}
